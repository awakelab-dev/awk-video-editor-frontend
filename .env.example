VITE_API_BASE_URL=http://localhost:4000
VITE_API_PROJECT_ID=123
# Temporary: comma-separated project ids to hydrate the gallery from project snapshots
# VITE_API_PROJECT_IDS=123,launch-q3,board-update-apr,onboarding-v2,product-demo-es
# Optional: custom project detail path for opening the editor
# VITE_API_PROJECT_PATH=/api/v1/projects/{projectId}/editor-state
# Optional: custom path template for snapshot autosave (supports {projectId})
# VITE_API_PROJECT_SNAPSHOT_PATH=/api/v1/projects/{projectId}/snapshot
# Optional: HTTP method for snapshot autosave (defaults to PUT)
VITE_API_PROJECT_SNAPSHOT_METHOD=PUT
